from .evaluation import *
from django.db import transaction
from django.views.decorators.csrf import csrf_exempt
import unicodedata


def build_table_data_for_eleve(id_eleve, id_annee, id_campus, id_cycle, id_classe):
    note_types = get_note_types()
    
    if len(note_types) != 2:
        raise ValueError(f"get_note_types doit retourner exactement 2 valeurs, mais {len(note_types)} reçues")
    tj_sigle, ex_sigle = note_types
    trimestres_data = get_trimestres(id_annee, id_campus, id_cycle, id_classe)
    
    if trimestres_data is None or len(trimestres_data) != 3:
        raise ValueError(f"get_trimestres doit retourner exactement 3 trimestres, mais {trimestres_data} reçu")
    trimestre_ids = [trimestre[0] for trimestre in trimestres_data]
    trimestre_noms = [trimestre[1] for trimestre in trimestres_data]
    table_data = initialize_table_data(trimestre_noms, tj_sigle, ex_sigle)
    cours_classe = get_cours_classe(id_annee, id_campus, id_cycle, id_classe)
    domaines_dict = build_domaines_dict(cours_classe)
    groupes = build_groupes(domaines_dict)
    table_data, totals, total_tp, total_tpe, total_max_tot = add_cours__notes_in_rows(
        table_data, groupes, id_eleve, id_annee, id_campus, id_cycle, id_classe
    )
    totals_by_trimestre = {tid: totals.get(tid, {'tj': 0, 'ex': 0, 'tot': 0}) for tid in trimestre_ids}
    table_data = get_totals_of_ponderation_cours(
        table_data, totals_by_trimestre, trimestre_ids, total_tp, total_tpe, total_max_tot
    )
    result = finalize_table_data_bulletin(
        table_data, len(table_data), id_eleve, id_annee, id_campus, id_cycle, id_classe
    )
    table_data, _, _ = result
    return table_data

@login_required
@module_required("Institeur et son Espace")
def get_pupils_list_for_complaints(request):
    id_annee = request.GET.get('id_annee')
    id_campus = request.GET.get('id_campus')
    id_cycle = request.GET.get('id_cycle')
    id_classe = request.GET.get('id_classe_active')
    
    if not all([id_annee, id_campus, id_cycle, id_classe]):
        return JsonResponse({'error': 'Paramètres manquants'}, status=400)
    trimestre = Annee_trimestre.objects.filter(id_annee=id_annee, id_campus=id_campus, id_cycle=id_cycle, id_classe=id_classe).order_by('id_trimestre').first()
    try:
        id_trimestre = trimestre.id_trimestre
        inscriptions = Eleve_inscription.objects.filter(
                id_annee=id_annee,
                id_campus=id_campus,
                id_classe_cycle=id_cycle,
                id_classe=id_classe,
                id_trimestre=id_trimestre,
                status=1
            ).select_related('id_eleve').distinct()
        pupils_with_complaints = []

        for inscription in inscriptions:
            eleve = inscription.id_eleve
            try:
                table_data = build_table_data_for_eleve(
                    id_eleve=eleve.id_eleve,
                    id_annee=id_annee,
                    id_campus=id_campus,
                    id_cycle=id_cycle,
                    id_classe=id_classe
                )
                repechage_courses = get_all_repechage_courses_on_fields(table_data)
                if len(repechage_courses)>=2:
                    pupils_with_complaints.append({
                    'id_eleve': eleve.id_eleve,
                    'nom_complet': f"{eleve.nom} {eleve.prenom}",
                    'id_campus': inscription.id_campus_id,
                    'id_cycle': inscription.id_classe_cycle_id,
                  })
            except Exception as e:
                continue
        return JsonResponse({
            'success': True,
            'data': pupils_with_complaints,
            'count': len(pupils_with_complaints)
        })

    except Exception as e:
        logger.critical(f"Erreur lors du traitement de la vue : {str(e)}")
        return JsonResponse({'error': str(e)}, status=500)

def remove_accents(input_str):
    """Supprime les accents d'une chaîne."""
    return ''.join(
        c for c in unicodedata.normalize('NFD', input_str)
        if unicodedata.category(c) != 'Mn'
    )

def get_all_repechage_courses_on_fields(table_data):
    """
    Extrait les trois cours avec un pourcentage < 50 %, sauf ceux liés à 'conduite',
    triés par pourcentage croissant.
    """
    repechage_courses = []

    for row in table_data:
        if not row or len(row) < 17 or row[0] in ['Total', '%', 'Place']:
            continue

        try:
            percentage_str = row[16]
            if isinstance(percentage_str, dict):
                value = percentage_str.get('value')
                if hasattr(value, 'text'):
                    percentage_str = value.text
                elif value:
                    percentage_str = str(value)
                else:
                    raise ValueError("Valeur vide dans dict")

            percentage_str = str(percentage_str).replace('%', '').strip()
            if not percentage_str:
                raise ValueError("Chaîne vide")
            percentage = float(percentage_str)

            cours_nom = None
            if isinstance(row[1], dict):
                cours_nom = row[1].get('value')
            else:
                cours_nom = row[1]

            if not cours_nom:
                if isinstance(row[0], dict):
                    cours_nom = row[0].get('value')
                else:
                    cours_nom = row[0]

            if not cours_nom or cours_nom in ['Total', '%', 'Place']:
                continue

            cours_nom_clean = remove_accents(cours_nom).lower()
            if "conduite" in cours_nom_clean:
                continue

            if percentage < 50.0:
                repechage_courses.append((cours_nom, percentage))

        except (ValueError, TypeError, AttributeError, IndexError):
            continue

    repechage_courses.sort(key=lambda x: x[1])
    course_names = [course[0] for course in repechage_courses[:3]]
    return course_names

@login_required
@module_required("Institeur et son Espace")
def get_repechage_courses_by_pupil(request):
    """Vue pour récupérer les cours à repêcher pour un élève via une requête HTTP."""
    id_eleve = request.GET.get('id_eleve')
    id_annee = request.GET.get('id_annee')
    id_campus = request.GET.get('id_campus')
    id_cycle = request.GET.get('id_cycle')
    id_classe = request.GET.get('id_classe')

    repechage_courses, error = get_repechage_courses_for_pupil_util(
        id_eleve=id_eleve,
        id_annee=id_annee,
        id_campus=id_campus,
        id_cycle=id_cycle,
        id_classe=id_classe
    )

    if error:
        return JsonResponse(error, status=400 if error['error'] == 'Paramètres manquants' else 500)

    eleve = Eleve_inscription.objects.filter(
        id_eleve=id_eleve,
        id_annee=id_annee,
        id_campus=id_campus,
        id_classe_cycle=id_cycle,
        id_classe=id_classe,
        status=1
    ).select_related('id_eleve').first()

    response_data = {
        'success': True,
        'eleve': {
            'id_eleve': eleve.id_eleve.id_eleve,
            'nom': eleve.id_eleve.nom,
            'prenom': eleve.id_eleve.prenom
        },
        'courses': repechage_courses,
        'count': len(repechage_courses)
    }
    return JsonResponse(response_data)

def get_repechage_courses_for_pupil_util(id_eleve, id_annee, id_campus, id_cycle, id_classe):
    """Fonction utilitaire pour récupérer les cours à repêcher pour un élève."""
    try:
        if not all([id_eleve, id_annee, id_campus, id_cycle, id_classe]):
            logger.warning("Paramètres manquants dans get_repechage_courses_for_pupil_util")
            return None, {'error': 'Paramètres manquants'}

        eleve = Eleve_inscription.objects.filter(
            id_eleve=id_eleve,
            id_annee=id_annee,
            id_campus=id_campus,
            id_classe_cycle=id_cycle,
            id_classe=id_classe,
            status=1
        ).select_related('id_eleve').first()

        if not eleve:
            logger.error(f"Aucun élève trouvé pour id_eleve={id_eleve} avec les paramètres donnés")
            return None, {'error': 'Élève non trouvé'}

        table_data = build_table_data_for_eleve(
            id_eleve=id_eleve,
            id_annee=id_annee,
            id_campus=id_campus,
            id_cycle=id_cycle,
            id_classe=id_classe
        )
        repechage_courses = get_all_repechage_courses_on_fields(table_data)
        return repechage_courses, None
    except Exception as e:
        return None, {'error': str(e)}

@login_required
@csrf_exempt
@module_required("Institeur et son Espace")
def update_note_after_repechages(request):
    if request.method != 'POST':
        return JsonResponse({"error": "Méthode non autorisée"}, status=405)
    try:
        data = json.loads(request.body)
        id_annee = data.get('id_annee')
        id_campus = data.get('id_campus')
        id_cycle = data.get('id_cycle')
        id_classe = data.get('id_classe')
        id_eleve = data.get('id_eleve')
        id_trimestre = data.get('id_trimestre')
        id_periode = data.get('id_periode')
        nom_cours = data.get('nom_cours') 
        note_rep = data.get('note_repechage')
        id_type_note = data.get('id_type_note')
        
        if not all([id_annee, id_campus, id_cycle, id_classe, id_eleve, id_trimestre,
                    id_periode, nom_cours, note_rep, id_type_note]):
            return JsonResponse({"error": "Paramètres manquants"}, status=400)

        with transaction.atomic():
            try:
                cours_obj = Cours_par_classe.objects.select_related('id_cours').get(
                    id_annee_id=id_annee,
                    id_campus_id=id_campus,
                    id_cycle_id=id_cycle,
                    id_classe_id=id_classe,
                    id_cours__cours=nom_cours
                )
            except Cours_par_classe.DoesNotExist:
                return JsonResponse({"error": "Cours introuvable"}, status=404)

            cours_classe_id = cours_obj.id_cours_classe
            tpe_max = cours_obj.TPE

            try:
                note_repech = float(note_rep)
            except ValueError:
                return JsonResponse({"error": "Note invalide"}, status=400)

            if note_repech > tpe_max:
                return JsonResponse({
                    "error": f"La note saisie ({note_repech}) dépasse le maximum autorisé ({tpe_max})."
                }, status=400)

            try:
                evaluation = Eleve_note.objects.get(
                    id_annee_id=id_annee,
                    id_campus_id=id_campus,
                    id_cycle_actif_id=id_cycle,
                    id_classe_active_id=id_classe,
                    id_eleve_id=id_eleve,
                    id_trimestre_id=id_trimestre,
                    id_periode_id=id_periode,
                    id_type_note_id=id_type_note,
                    id_cours_classe_id=cours_classe_id
                )
            except Eleve_note.DoesNotExist:
                return JsonResponse({"error": f"Cet eleve n'a pas fait l'examen de ce cours car la note de ce cours n'est pas connue!Veuillez verifier s'il vous plait!"}, status=404)

            evaluation.note_repechage = note_repech
            evaluation.save(update_fields=['note_repechage'])

        return JsonResponse({"success": True})

    except json.JSONDecodeError:
        return JsonResponse({"error": "Format JSON invalide"}, status=400)

    except Exception as e:
        return JsonResponse({"error": str(e)}, status=500)
